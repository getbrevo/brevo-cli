{
  "name": "@getbrevo/cli",
  "version": "1.2.0",
  "author": "Brevo",
  "description": "Brevo Developer CLI — create, manage apps and OAuth integrations",
  "type": "commonjs",
  "main": "dist/bin/index.js",
  "files": [
    "dist",
    "agent-context",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "brevo": "dist/bin/index.js"
  },
  "engines": {
    "node": ">=20.15.0",
    "yarn": ">=1.19.1"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.cpSync('src/templates/files','dist/templates/files',{recursive:true})\"",
    "postbuild": "node -e \"try{require('fs').chmodSync('dist/bin/index.js',0o755)}catch{}\"",
    "dev": "tsc --watch",
    "unlink": "yarn unlink",
    "link:dev": "yarn build && yarn link",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --coverage --passWithNoTests",
    "lint": "eslint 'src/**/*.ts' --quiet",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "mock": "npx @stoplight/prism-cli mock mock/openapi.yaml --port 3112",
    "smoke": "tsx scripts/smoke-test.ts",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "publish:packages": "changeset publish"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^8.2.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix --quiet"
    ]
  },
  "keywords": [
    "brevo",
    "cli",
    "oauth",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getbrevo/brevo-cli.git"
  },
  "homepage": "https://github.com/getbrevo/brevo-cli#readme",
  "bugs": {
    "url": "https://github.com/getbrevo/brevo-cli/issues",
    "email": "support@brevo.com"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
